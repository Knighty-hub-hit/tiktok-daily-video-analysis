{
  "name": "site-creator-vinext-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern .dev-tools",
    "data:import": "node scripts/refresh-site-data.mjs",
    "data:dashboard": "node scripts/build-dashboard-data.mjs",
    "data:validate": "node scripts/validate-site-data.mjs",
    "feishu:import": "node scripts/import-feishu-sheet-to-site-data.mjs",
    "feishu:prepare": "python3 scripts/prepare-feishu-excel-data.py",
    "feishu:merge-csv": "node scripts/merge-feishu-csv-with-prepared.mjs",
    "feishu:sync": "node scripts/sync-feishu-sheet-from-tiktok-report.mjs",
    "feishu:notify": "node scripts/send-feishu-site-notification.mjs",
    "media:enrich": "node scripts/enrich-tiktok-media.mjs",
    "daren:prepare": "python3 scripts/prepare-daren-video-total.py",
    "report:download": "node scripts/download-tiktok-report.mjs",
    "tiktok:session": "node scripts/capture-tiktok-session.mjs",
    "tiktok:export-browser": "node scripts/export-tiktok-report-with-browser.mjs",
    "pages:build": "npm run data:dashboard && GITHUB_PAGES=true NEXT_PUBLIC_SITE_BASE_PATH=/tiktok-daily-video-analysis next build --webpack",
    "pages:check": "npm run data:validate && npm run pages:build",
    "miaoda:build": "npm run data:dashboard && GITHUB_PAGES=true NEXT_PUBLIC_SITE_BASE_PATH=/app/app_179t4tka49p next build --webpack",
    "miaoda:prepare": "node scripts/prepare-miaoda-html.mjs out",
    "miaoda:publish": "npm run data:validate && npm run miaoda:build && npm run miaoda:prepare && lark-cli apps +html-publish --app-id app_179t4tka49p --path ./out --as user",
    "workflow:check": "npm run data:validate && npm run data:dashboard && npm run build",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.61.1",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
