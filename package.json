{
  "name": "site-creator-vinext-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern .dev-tools",
    "data:import": "node scripts/refresh-site-data.mjs",
    "data:validate": "node scripts/validate-site-data.mjs",
    "feishu:import": "node scripts/import-feishu-sheet-to-site-data.mjs",
    "feishu:prepare": "python3 scripts/prepare-feishu-excel-data.py",
    "feishu:sync": "node scripts/sync-feishu-sheet-from-tiktok-report.mjs",
    "daren:prepare": "python3 scripts/prepare-daren-video-total.py",
    "report:download": "node scripts/download-tiktok-report.mjs",
    "pages:build": "GITHUB_PAGES=true NEXT_PUBLIC_SITE_BASE_PATH=/tiktok-daily-video-analysis next build --webpack",
    "pages:check": "npm run data:validate && npm run pages:build",
    "workflow:check": "npm run data:validate && npm run build",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
